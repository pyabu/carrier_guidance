{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 60,
        "maxLambdaSize": "512mb",
        "includeFiles": [
          "templates/**",
          "static/**",
          "data/**",
          "sitemap.xml",
          "robots.txt",
          "generate_sitemap.py",
          "seo_diagnostic.py",
          "verify_sitemap.py",
          "SEO_IMPROVEMENTS.md",
          ".env"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "^/(sitemap\\.xml/|sitemap_index\\.xml)$",
      "status": 308,
      "dest": "/sitemap.xml"
    },
    {
      "src": "^/robots\\.txt/$",
      "status": 308,
      "dest": "/robots.txt"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/scraper",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/tn",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/india",
      "schedule": "0 1 * * *"
    }
  ]
}
